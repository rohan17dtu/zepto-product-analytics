      <column caption='Cancellation Rate' datatype='real' name='[Calculation_1701856356528128]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#10;IF [OrderStatus] = &quot;Cancelled&quot;&#10;THEN 1&#10;ELSE 0&#10;END&#10;)&#10;/COUNT([OrderID])' />
      </column>
      <column caption='Delivery Bucket' datatype='string' name='[Calculation_1701856367075329]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [DeliveryMinutes] &lt;=10 THEN &quot;0-10 min&quot;&#10;&#10;ELSEIF [DeliveryMinutes] &lt;=20 THEN &quot;11-20 min&quot;&#10;&#10;ELSEIF [DeliveryMinutes] &lt;=30 THEN &quot;21-30 min&quot;&#10;&#10;ELSE &quot;30+ min&quot;&#10;&#10;END' />
